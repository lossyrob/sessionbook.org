{
  "name": "sessionbook.org",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": "22.14.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "db:setup": "tsx scripts/db-setup.ts",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "generate:release-1-data": "tsx scripts/generate-release-1-data.ts",
    "generate:session-content": "tsx scripts/generate-session-content.ts",
    "render:session-pdf": "tsx scripts/render-session-pdf.ts",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,css,json,md}": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "next": "16.2.1",
    "postgres": "^3.4.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
}
