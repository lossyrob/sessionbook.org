{
  "name": "sessionbook.org",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": "22.14.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run db:setup && next build",
    "db:setup": "tsx scripts/db-setup.ts",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "16.2.1",
    "postgres": "^3.4.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
}
