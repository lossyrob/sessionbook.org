{
  "hosting": [
    {
      "target": "prod",
      "public": "public",
      "cleanUrls": true,
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "run": {
            "serviceId": "sessionbook-web-prod",
            "region": "us-central1",
            "pinTag": true
          }
        }
      ]
    },
    {
      "target": "staging",
      "public": "public",
      "cleanUrls": true,
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "run": {
            "serviceId": "sessionbook-web-staging",
            "region": "us-central1",
            "pinTag": true
          }
        }
      ]
    }
  ]
}
