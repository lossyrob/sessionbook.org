# SessionBook Environment Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — do not commit it.

# Google Cloud / Firebase
GCP_PROJECT_ID=
FIREBASE_PROJECT_ID=
FIREBASE_PROD_SITE_ID=
FIREBASE_STAGING_SITE_ID=
PROD_DOMAIN=
STAGING_DOMAIN=

# Postgres
# Use a standard Postgres connection string here. This can point at:
# - local Docker Postgres for development
# - Neon staging/prod databases
# Example local Docker value:
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/sessionbook
DATABASE_URL=

# Web app
# When browser-visible config is introduced later, use the NEXT_PUBLIC_ prefix.
# Example:
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
